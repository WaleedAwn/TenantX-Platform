{
  "ConnectionStrings": {
    "Database": "Host=localhost;Port=5432;Database=tenantx_db;Username=postgres;Password=postgres;Include Error Detail=true"
  },
  "Serilog": {
    "Using": ["Serilog.Sinks.Console"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information"
      }
    },
    "WriteTo": [{ "Name": "Console" }],
    "Enrich": ["FromLogContext", "WithMachineName", "WithThreadId"],
    "Properties": {
      "Application": "TenantX.Api"
    }
  }
}
